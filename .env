# 1. Variables for the Postgres Container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=abc@123
POSTGRES_DB=scraper_db

# 2. Variables for your Go Apps (Scraper/Summarizer)
# We use 'db' because that is the service name in docker-compose
DB_URL=postgres://postgres:abc@123@db:5432/scraper_db
OLLAMA_HOST=http://ollama:11434

